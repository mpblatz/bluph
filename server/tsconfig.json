{
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "../",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ESNext",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "ts-node": {
        "esm": true
    },
    "include": ["src/**/*", "../shared/**/*"]
}
